<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WeatherApp.UI.MainWindow"
        Title="WeatherApp"
        Width="500" Height="300"
        Background="White">
        
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" ColumnDefinitions="*" Margin="12">
    
    <!-- Title -->
    <TextBlock Grid.Row="0" Text="WeatherApp - Get Weather" FontSize="20" FontWeight="Bold" Foreground="Black" Margin="0,0,0,8"/>
    
    <!-- Input Row -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBox Width="250" Watermark="Enter city name" 
               Text="{Binding City, Mode=TwoWay}" 
               IsEnabled="{Binding GetWeatherCommand.IsRunning, Converter={StaticResource InverseBool}}"
               Foreground="Black" 
               Background="White" 
               BorderThickness="2" 
               BorderBrush="Black"
               Padding="8,6"/>
      
      <Button Width="120" Content="Get Weather" 
              Command="{Binding GetWeatherCommand}" 
              IsEnabled="{Binding GetWeatherCommand.IsRunning, Converter={StaticResource InverseBool}}"
              Foreground="White" 
              Background="#0078d4" 
              FontWeight="Bold"
              Padding="8,6"/>
    </StackPanel>
    
    <!-- Progress Bar -->
    <ProgressBar Grid.Row="2" IsIndeterminate="True" IsVisible="{Binding GetWeatherCommand.IsRunning}" 
                 Height="8" Margin="0,0,0,8" Background="#e0e0e0" Foreground="#0078d4"/>
    
    <!-- Results Area -->
    <StackPanel Grid.Row="3" Spacing="6">
      <TextBlock Text="Weather Details:" FontWeight="Bold" Foreground="Black" FontSize="14"/>
      <Border BorderBrush="#cccccc" BorderThickness="1" Background="#f5f5f5" Padding="8" CornerRadius="4">
        <StackPanel Spacing="4">
          <TextBlock Text="{Binding TemperatureDisplay}" Foreground="Black" FontSize="16" FontWeight="Bold"/>
          <TextBlock Text="{Binding Description}" Foreground="#333333" FontSize="13"/>
        </StackPanel>
      </Border>
    </StackPanel>
    
    <!-- Error Message -->
    <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}" 
               Foreground="#cc0000" 
               FontSize="13"
               TextWrapping="Wrap"
               VerticalAlignment="Bottom"
               Margin="0,8,0,0"/>
  </Grid>
</Window>
