<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WeatherApp.UI.MainWindow"
        Title="WeatherApp"
        Width="480" Height="240">
  <StackPanel Margin="12" Spacing="8">
    <TextBlock Text="WeatherApp (MVP)" FontSize="18"/>

    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBox Width="240" Watermark="Enter city" Text="{Binding City, Mode=TwoWay}" />
      <Button Content="Get Weather" Command="{Binding GetWeatherCommand}" />
    </StackPanel>

    <TextBlock Text="Results:" FontWeight="Bold"/>
    <TextBlock Text="{Binding TemperatureDisplay}"/>
    <TextBlock Text="{Binding Description}"/>
    <TextBlock Foreground="Red" Text="{Binding ErrorMessage}"/>
  </StackPanel>
</Window>
