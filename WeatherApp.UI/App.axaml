<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="WeatherApp.UI.App"
             xmlns:local="clr-namespace:WeatherApp.UI.Converters">
  <Application.Resources>
    <local:InverseBooleanConverter x:Key="InverseBool" />
  </Application.Resources>

  <Application.Styles>
    <!-- Minimal styles; can be extended with Fluent theme -->
  </Application.Styles>
</Application>
